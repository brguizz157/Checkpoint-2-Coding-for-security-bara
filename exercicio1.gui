frase = input("Digite uma frase: ")
frase = frase.lower()

vogais = "aeiou찼챕챠처첬횪챔챙챵첫찾천창챗챤척청"

contador_vogais = 0
contador_consoantes = 0

for letra in frase:
    if letra.isalpha():
        if letra in vogais:
            contador_vogais += 1
        else:
            contador_consoantes += 1

print(f"Vogais encontradas: {contador_vogais}")
print(f"Consoantes encontradas: {contador_consoantes}")
